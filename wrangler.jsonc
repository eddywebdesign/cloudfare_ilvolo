{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ilvolodellasera",
  "compatibility_date": "2026-06-30",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
