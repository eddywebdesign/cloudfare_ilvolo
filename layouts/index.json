{{- $items := where .Site.RegularPages "Section" "episodi" -}}
[
{{- range $i, $p := $items -}}
  {{- if $i }},{{ end -}}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
    "temi": {{ $p.Params.temi | jsonify }},
    "resumen": {{ $p.Params.resumen | jsonify }}
  }
{{- end -}}
]
